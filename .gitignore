# ── Data directories (too large for GitHub) ────────────────────────────────
# Place study-area data in these folders locally; they are NOT tracked.
PineValley_Data/
SierraValley_Data/
statewide/
basins/

# ── Output (regenerated by running the workflow) ───────────────────────────
output/

# ── Raster and geospatial data files ──────────────────────────────────────
*.tif
*.tiff
*.tif.aux.xml
*.tiff.aux.xml
*.img
*.hdf
*.nc

# ── Shapefiles ────────────────────────────────────────────────────────────
# The NWI_Investigations shapefile in etg_fill/ IS tracked (negated below).
# Data shapefiles live in the ignored study-area folders above.
*.shp
*.shx
*.dbf
*.prj
*.sbn
*.sbx
*.cpg
*.qix
*.shp.xml

# ── Force-include the NWI shapefile (needed for basin boundary masks) ─────
!etg_fill/NWI_Investigations.shp
!etg_fill/NWI_Investigations.shx
!etg_fill/NWI_Investigations.dbf
!etg_fill/NWI_Investigations.prj
!etg_fill/NWI_Investigations.cpg
!etg_fill/NWI_Investigations.qix
!etg_fill/NWI_Investigations.shp.xml

# ── Python ─────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.egg-info/
*.egg
dist/
build/

# ── OS junk ────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── IDE / editor ──────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── Misc ──────────────────────────────────────────────────────────────────
*.zip
*.log
