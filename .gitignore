# ── Data directories (too large for GitHub) ────────────────────────────────
# Place study-area data in these folders locally; they are NOT tracked.
PineValley_Data/
SierraValley_Data/
statewide/
basins/

# ── Output (regenerated by running the workflow) ───────────────────────────
output/

# ── Raster and geospatial data files ──────────────────────────────────────
*.tif
*.tiff
*.tif.aux.xml
*.tiff.aux.xml
*.img
*.hdf
*.nc
*.aux.xml
*.ovr

# ── Shapefiles ────────────────────────────────────────────────────────────
# The NWI_Investigations_EPSG_32611 shapefile at the repo root IS tracked (negated below).
# Data shapefiles live in the ignored study-area folders above.
*.shp
*.shx
*.dbf
*.prj
*.sbn
*.sbx
*.cpg
*.qix
*.shp.xml

# ── Force-include the NWI shapefile (needed for basin boundary masks) ─────
!NWI_Investigations_EPSG_32611.shp
!NWI_Investigations_EPSG_32611.shx
!NWI_Investigations_EPSG_32611.dbf
!NWI_Investigations_EPSG_32611.prj
!NWI_Investigations_EPSG_32611.cpg
!NWI_Investigations_EPSG_32611.qix
!NWI_Investigations_EPSG_32611.shp.xml

# ── Python ─────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.egg-info/
*.egg
dist/
build/
.env
.venv/
env/
venv/

# ── OS junk ────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── IDE / editor ──────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── Misc ──────────────────────────────────────────────────────────────────
*.zip
*.log
*.csv
*.xlsx
*.xml
